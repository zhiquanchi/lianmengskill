{
  "manifest_version": 3,
  "name": "Grok AI Assistant",
  "version": "0.1.0",
  "description": "Send questions to Grok AI and save conversations to local database",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "https://grok.com/*",
    "https://grok.x.com/*",
    "https://chat.x.ai/*",
    "https://x.com/i/grok*",
    "https://simplycodes.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "ws://127.0.0.1/*",
    "ws://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "打开 Grok AI Assistant 侧栏"
    }
  },
  "action": {
    "default_title": "Grok AI Assistant",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://grok.com/*",
        "https://grok.x.com/*",
        "https://chat.x.ai/*",
        "https://x.com/i/grok*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}