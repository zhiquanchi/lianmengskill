# Environment variables for Grok AI Browser Extension
# Copy this file to .env and adjust values as needed

# WebSocket server settings
WS_HOST=127.0.0.1
WS_PORT=8765

# Database settings
DATABASE_URL=sqlite+aiosqlite:///./grok_conversations.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Extension settings (these can also be configured in the extension popup)
DEFAULT_GROK_URL=https://chat.x.ai
AUTO_OPEN_TAB=true

# Development settings
DEBUG=false
RELOAD=false